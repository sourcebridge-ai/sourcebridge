# --- Living-Wiki Settings ---

"""
LivingWikiSettings is the UI-managed living-wiki configuration.

Secret fields (tokens, webhook secrets) are never returned in plaintext.
When a secret has been stored, its value is the sentinel string "********".
A non-sentinel value in an UpdateLivingWikiSettingsInput replaces the stored
secret; the sentinel value is treated as "do not change".
"""
type LivingWikiSettings {
  enabled: Boolean
  workerCount: Int
  eventTimeout: String
  githubToken: String
  gitlabToken: String
  """
  confluenceSite is the Atlassian Cloud site subdomain (e.g. "mycompany" for
  mycompany.atlassian.net). Not a secret; returned in plaintext.
  """
  confluenceSite: String
  confluenceEmail: String
  confluenceToken: String
  notionToken: String
  confluenceWebhookSecret: String
  notionWebhookSecret: String
  updatedAt: Time
  updatedBy: String
  """
  killSwitchActive is true when SOURCEBRIDGE_LIVING_WIKI_KILL_SWITCH=true is
  set on the server at boot time. When true, the dispatcher is not running
  even if enabled=true. The UI uses this to render State 1 (kill-switch
  active) rather than the activation gate.
  """
  killSwitchActive: Boolean!
}

input UpdateLivingWikiSettingsInput {
  enabled: Boolean
  workerCount: Int
  eventTimeout: String
  githubToken: String
  gitlabToken: String
  confluenceSite: String
  confluenceEmail: String
  confluenceToken: String
  notionToken: String
  confluenceWebhookSecret: String
  notionWebhookSecret: String
}

type LivingWikiConnectionTestResult {
  provider: String!
  ok: Boolean!
  message: String
}

# ─────────────────────────────────────────────────────────────────────────────
# Per-repo living-wiki types
# ─────────────────────────────────────────────────────────────────────────────

type RepositoryLivingWikiSettings {
  enabled: Boolean!
  mode: RepoWikiMode!
  sinks: [RepoWikiSink!]!
  excludePaths: [String!]!
  staleWhenStrategy: RepoStaleWhenStrategy!
  maxPagesPerJob: Int!
  lastRunAt: Time
  updatedAt: Time
  updatedBy: String
  """
  The most recent job result for this repo, surfaced in the settings panel
  summary. Null when no job has been run yet.
  """
  lastJobResult: LivingWikiJobResult
}

type RepoWikiSink {
  kind: RepoWikiSinkKind!
  integrationName: String!
  """Audience is per-sink, not per-repo."""
  audience: RepoWikiAudience!
  editPolicy: RepoWikiEditPolicy!
}

type LivingWikiJobResult {
  jobId: String!
  startedAt: Time!
  completedAt: Time
  pagesPlanned: Int!
  pagesGenerated: Int!
  pagesExcluded: Int!
  """
  Page IDs excluded in this job. Used by the retryExcludedOnly path on the
  next enableLivingWikiForRepo call.
  """
  excludedPageIds: [String!]!
  """
  Titles of pages generated by this job. Historical — does not reflect the
  current PageStore state.
  """
  generatedPageTitles: [String!]!
  exclusionReasons: [String!]!
  """
  status is one of: running, ok, partial, failed.
  """
  status: String!
  """
  failureCategory classifies terminal failures into one of three buckets that
  drive distinct CTAs in the UI. Values: transient, auth, partial_content.
  Empty when status is ok, partial, or running.
  """
  failureCategory: String
  errorMessage: String
}

enum RepoWikiMode {
  PR_REVIEW
  DIRECT_PUBLISH
}

enum RepoWikiAudience {
  ENGINEER
  PRODUCT
  OPERATOR
}

enum RepoWikiSinkKind {
  GIT_REPO
  CONFLUENCE
  NOTION
  GITHUB_WIKI
  GITLAB_WIKI
  BACKSTAGE_TECHDOCS
  MKDOCS
  DOCUSAURUS
  VITEPRESS
}

enum RepoWikiEditPolicy {
  PROPOSE_PR
  DIRECT_PUBLISH
}

enum RepoStaleWhenStrategy {
  DIRECT
  TRANSITIVE
}

input UpdateRepositoryLivingWikiSettingsInput {
  repositoryId: ID!
  enabled: Boolean
  mode: RepoWikiMode
  sinks: [RepoWikiSinkInput!]
  excludePaths: [String!]
  staleWhenStrategy: RepoStaleWhenStrategy
  maxPagesPerJob: Int
}

input RepoWikiSinkInput {
  kind: RepoWikiSinkKind!
  integrationName: String!
  audience: RepoWikiAudience!
  """
  Omit to use the default edit policy for the sink kind.
  Stage A silently applies the default; Stage B exposes it for override.
  """
  editPolicy: RepoWikiEditPolicy
}

"""
enableLivingWikiForRepo saves the repo settings and enqueues the cold-start
job. Returns jobId so the UI can track progress via the activity feed.

Kill-switch behavior: if SOURCEBRIDGE_LIVING_WIKI_KILL_SWITCH=true is set,
the mutation persists settings but returns jobId: null and a non-null notice.
Globally-disabled behavior: if the global LivingWikiSettings.enabled is false,
the same notice+null pattern applies.
"""
input EnableLivingWikiForRepoInput {
  repositoryId: ID!
  mode: RepoWikiMode!
  sinks: [RepoWikiSinkInput!]!
  """
  When true, restrict the cold-start job to re-attempting only the pages that
  were excluded in the most recent job (from lw_job_results.excluded_page_ids).
  Used by the "Retry excluded pages" CTA. Defaults to false (full run).
  """
  retryExcludedOnly: Boolean
}

type EnableLivingWikiResult {
  settings: RepositoryLivingWikiSettings!
  """
  jobId is visible in the LLM activity feed. Null in two cases:
  1. Living-wiki is globally disabled.
  2. SOURCEBRIDGE_LIVING_WIKI_KILL_SWITCH=true is set.
  In both cases notice is non-null.
  """
  jobId: String
  """
  notice is non-null when settings were saved but no job was enqueued.
  The UI renders this as an informational banner (not a toast).
  """
  notice: String
}
