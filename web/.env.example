# API server URL for the Next.js development proxy and client-side code.
# This should point to the Go API server.
NEXT_PUBLIC_API_URL=http://localhost:8080

# PostHog product analytics (optional). Leave blank to disable.
# NEXT_PUBLIC_POSTHOG_KEY=phx_your_project_api_key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
