# SourceBridge configuration — copy to config.toml and adjust as needed.
#
# Environment variables override file values. The env prefix is SOURCEBRIDGE_
# with nested keys joined by underscores, e.g. SOURCEBRIDGE_LLM_BASE_URL.

# ─── Telemetry ─────────────────────────────────────────────────────
# Anonymous usage data helps us improve SourceBridge. No PII is collected.
# Disable via SOURCEBRIDGE_TELEMETRY=off or DO_NOT_TRACK=1.
# [telemetry]
# enabled = true

# ─── Cloud mode (Anthropic) — best quality, requires API key ───────
# [llm]
# provider = "anthropic"
# base_url = ""                          # leave empty for SDK default
# summary_model = "claude-sonnet-4-20250514"
# review_model  = "claude-sonnet-4-20250514"
# ask_model     = "claude-sonnet-4-20250514"

# ─── Local mode (Ollama) — free, runs on your machine ──────────────
[llm]
provider = "ollama"
base_url = "http://localhost:11434/v1"
summary_model = "qwen3:32b"
review_model  = "qwen3:32b"
ask_model     = "qwen3:32b"
# report_model  = ""            # Optional: override model for report generation
                                 # Leave empty to use summary_model
# [llm.report]                  # Optional: separate provider for reports
# provider = "anthropic"
# model = "claude-sonnet-4-20250514"
# api_key = ""

# ─── Local mode (vLLM) ────────────────────────────────────────────
# [llm]
# provider = "vllm"
# base_url = "http://localhost:8000/v1"
# summary_model = "Qwen/Qwen2.5-32B-Instruct"
# review_model  = "Qwen/Qwen2.5-32B-Instruct"
# ask_model     = "Qwen/Qwen2.5-32B-Instruct"

[server]
http_port = 8080
grpc_port = 50051

[storage]
surreal_mode = "embedded"

[security]
mode = "oss"

# ─── Knowledge artifact invalidation ───────────────────────────────
# When a repository is reindexed, knowledge artifacts (cliff notes, diagrams,
# learning paths, etc.) need to be re-examined for freshness. Two env vars
# tune this:
#
# SOURCEBRIDGE_SELECTIVE_INVALIDATION (default: true)
#   When true, only artifacts whose persisted evidence references a changed
#   symbol or file are marked stale. Artifacts without usable provenance
#   (missing or whole-repo-only evidence) conservatively fall back to
#   blanket-stale so nothing silently drifts.
#   Set to "false" / "0" / "off" to restore the legacy always-blanket
#   behavior.
#
# SOURCEBRIDGE_SELECTIVE_INVALIDATION_MAX_CHANGES (default: 200)
#   Upper bound on (changed symbols + changed files) passed to the selective
#   query. Beyond this threshold the system falls back to blanket stale,
#   because the selective query would produce a near-universal-stale result
#   anyway.
