# SourceBridge configuration — copy to config.toml and adjust as needed.
#
# Environment variables override file values. The env prefix is SOURCEBRIDGE_
# with nested keys joined by underscores, e.g. SOURCEBRIDGE_LLM_BASE_URL.

# ─── Telemetry ─────────────────────────────────────────────────────
# Anonymous usage data helps us improve SourceBridge. No PII is collected.
# Disable via SOURCEBRIDGE_TELEMETRY=off or DO_NOT_TRACK=1.
# [telemetry]
# enabled = true

# ─── Cloud mode (Anthropic) — best quality, requires API key ───────
# [llm]
# provider = "anthropic"
# base_url = ""                          # leave empty for SDK default
# summary_model = "claude-sonnet-4-20250514"
# review_model  = "claude-sonnet-4-20250514"
# ask_model     = "claude-sonnet-4-20250514"

# ─── Local mode (Ollama) — free, runs on your machine ──────────────
[llm]
provider = "ollama"
base_url = "http://localhost:11434/v1"
summary_model = "qwen3:32b"
review_model  = "qwen3:32b"
ask_model     = "qwen3:32b"
# report_model  = ""            # Optional: override model for report generation
                                 # Leave empty to use summary_model
# [llm.report]                  # Optional: separate provider for reports
# provider = "anthropic"
# model = "claude-sonnet-4-20250514"
# api_key = ""

# ─── Local mode (vLLM) ────────────────────────────────────────────
# [llm]
# provider = "vllm"
# base_url = "http://localhost:8000/v1"
# summary_model = "Qwen/Qwen2.5-32B-Instruct"
# review_model  = "Qwen/Qwen2.5-32B-Instruct"
# ask_model     = "Qwen/Qwen2.5-32B-Instruct"

[server]
http_port = 8080
grpc_port = 50051

[storage]
surreal_mode = "embedded"

[security]
mode = "oss"

# ─── Knowledge artifact invalidation ───────────────────────────────
# When a repository is reindexed, knowledge artifacts (cliff notes, diagrams,
# learning paths, etc.) need to be re-examined for freshness. Two env vars
# tune this:
#
# SOURCEBRIDGE_SELECTIVE_INVALIDATION (default: true)
#   When true, only artifacts whose persisted evidence references a changed
#   symbol or file are marked stale. Artifacts without usable provenance
#   (missing or whole-repo-only evidence) conservatively fall back to
#   blanket-stale so nothing silently drifts.
#   Set to "false" / "0" / "off" to restore the legacy always-blanket
#   behavior.
#
# SOURCEBRIDGE_SELECTIVE_INVALIDATION_MAX_CHANGES (default: 200)
#   Upper bound on (changed symbols + changed files) passed to the selective
#   query. Beyond this threshold the system falls back to blanket stale,
#   because the selective query would produce a near-universal-stale result
#   anyway.

# ─── Phase 2: Delta-driven auto-regeneration ──────────────────────
# When artifacts are marked stale by selective invalidation (above),
# Phase 2 can automatically enqueue regeneration in the background so
# the user doesn't have to click "refresh" for every stale artifact.
#
# SOURCEBRIDGE_DELTA_REGEN_MODE (default: off)
#   off    — no auto-regen logic runs (recommended default).
#   shadow — the driver runs every decision step (candidate selection,
#            prioritization, per-reindex cap, per-repo-per-hour rate limit,
#            understanding-first gating) and emits telemetry describing
#            what it WOULD enqueue, but skips the actual enqueue. Use
#            this to observe the cost and decision quality on real
#            traffic before committing to live.
#   live   — full auto-regen: stale artifacts are regenerated in the
#            background on the prewarm priority queue.
#   Requires SOURCEBRIDGE_SELECTIVE_INVALIDATION=true; otherwise forced to
#   off regardless of this setting.
#
# SOURCEBRIDGE_DELTA_REGEN_MAX_PER_INDEX (default: 5)
#   Cap on how many artifacts can be auto-regenerated per reindex.
#   Remainder stay stale until a manual refresh.
#
# SOURCEBRIDGE_DELTA_REGEN_MAX_PER_REPO_PER_HOUR (default: 20)
#   Rolling-hour cap per repo. Protects against reindex thrash (a user
#   reindexing 20×/hour won't spawn 20 regen waves).

# ─── Deep-QA server-side orchestrator ────────────────────────────
# The server-side QA orchestrator (internal/qa) owns both fast and
# deep question answering for hosted deployments. Local-desktop
# installs keep the subprocess fast path by default so developers
# retain working-tree visibility (uncommitted edits).

# SOURCEBRIDGE_QA_SERVER_SIDE_ENABLED (default: false)
#   Turns on POST /api/v1/ask, the ask GraphQL mutation, and the
#   MCP ask_question tool. Default off through the parity benchmark
#   phase; flip to true once the paired benchmark report is in-repo.

# SOURCEBRIDGE_QA_LOCAL_FAST_MODE_SUBPROCESS (default: true)
#   Keeps the CLI subprocess fast path active on local-desktop
#   installs. Hosted / multi-tenant installs set this false once
#   they've validated the server path.

# SOURCEBRIDGE_QA_QUESTION_MAX_BYTES (default: 4096)
#   Hard cap on question length. Requests over this cap return 400.

# SOURCEBRIDGE_QA_SESSION_TOKENS_PER_HOUR (default: 100000)
# SOURCEBRIDGE_QA_REPO_TOKENS_PER_DAY (default: 1000000)
# SOURCEBRIDGE_QA_DEPLOYMENT_TOKENS_PER_DAY (default: 10000000)
#   Token-budget rate limits. Zero disables a layer. Exceeding any
#   returns 429 with Retry-After.

# SOURCEBRIDGE_QA_SYNTHESIS_LANE (default: 4)
#   Concurrent synthesis calls against the reasoning worker. Keeps
#   QA and embedding-search from starving each other under load.
